---
import Layout from '../layouts/Layout.astro'
import BackButton from '../components/BackButton.astro'
import Footer from '../components/Footer.astro'
import Alert from '../components/Alert.astro'
import FileUploader from '../components/FileUploader.astro'
import { CATEGORIAS, CIUDADES_PREDEFINIDAS } from '../utils/constants'
---

<Layout title="Comercio Local - Registrarse">
  <main
    class="max-w-xl mx-auto px-6 pt-10 pb-12 flex flex-col min-h-screen justify-between"
  >
    <div class="loading-screen" id="loading-screen">
      <div class="loading-spinner"></div>
    </div>
    <div class="w-full">
      <div
        class="flex items-center justify-between pb-4 mb-6"
        style="border-bottom: 1px solid var(--border-strongest)"
      >
        <div>
          <h1
            class="text-2xl font-bold tracking-wide"
            style="color: var(--primary)"
          >
            Comercio Local
          </h1>
          <p class="text-xs mt-1" style="color: var(--tertiary)">
            Sumate a la cartelera independiente de tu localidad
          </p>
        </div>
        <BackButton />
      </div>

      <div
        class="p-6 rounded-3xl border backdrop-blur-md"
        style="background: var(--elevated-60); border-color: var(--border-strongest)"
      >
        <Alert type="error" id="alerta-registro" />

        <form id="form-registro" class="space-y-6">
          <div class="space-y-4">
            <h2
              class="text-sm font-bold text-emerald-400 uppercase tracking-wider pb-1.5"
              style="border-bottom: 1px solid var(--border-strongest)"
            >
              Datos Comerciales o Profesional
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="nombreEmprendimiento"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Nombre del Emprendimiento
                </label>
                <input
                  id="nombreEmprendimiento"
                  type="text"
                  required
                  placeholder="Ej: Carlos Albornoz o La Cocina de Mabel"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>

              <div>
                <label
                  for="categoria"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Rubro / Categoría
                </label>
                <select
                  id="categoria"
                  required
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors cursor-pointer"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                >
                  <option value="" disabled selected>
                    Selecciona un rubro
                  </option>
                  {
                    CATEGORIAS.map((cat) => (
                      <option value={cat.value}>{cat.label}</option>
                    ))
                  }
                </select>
              </div>
            </div>

            <div>
              <div class="flex justify-between items-center mb-2">
                <label
                  for="descripcion"
                  class="block text-xs font-semibold uppercase tracking-wider"
                  style="color: var(--tertiary)"
                >
                  Descripción Breve o Biografía
                </label>
                <span
                  id="char-counter"
                  class="text-[10px] font-medium"
                  style="color: var(--tertiary)">0 / 150</span
                >
              </div>
              <textarea
                id="descripcion"
                required
                maxlength="150"
                rows="3"
                placeholder="Describe qué ofreces o cuál es tu especialidad. Máximo 150 caracteres."
                class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors resize-none"
                style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
              ></textarea>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <FileUploader id="logo" label="Logo o Avatar (Opcional)" />
              <FileUploader id="portada" label="Banner de Portada (Opcional)" />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="whatsapp"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  WhatsApp de Contacto
                </label>
                <input
                  id="whatsapp"
                  type="tel"
                  required
                  placeholder="Ej: 5491123456789"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
                <span
                  class="block text-[10px] mt-1 pl-1"
                  style="color: var(--quaternary)"
                  >Código de país + número, sin signos + ni guiones.</span
                >
              </div>

              <div>
                <label
                  for="ciudad"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Localidad / Ciudad
                </label>
                <select
                  id="ciudad"
                  required
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors cursor-pointer"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                >
                  <option value="" disabled selected>
                    Selecciona tu localidad
                  </option>
                  {
                    CIUDADES_PREDEFINIDAS.map((city) => (
                      <option value={city}>{city}</option>
                    ))
                  }
                  <option value="otra">Otra localidad...</option>
                </select>
              </div>
            </div>

            <div id="otra-ciudad-container" class="hidden">
              <label
                for="otraCiudad"
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: var(--tertiary)"
              >
                Nombre de tu Localidad
              </label>
              <input
                id="otraCiudad"
                type="text"
                placeholder="Ingresa tu ciudad o localidad"
                class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
              />
            </div>

            <div>
              <label
                for="direccion"
                class="block text-xs font-semibold uppercase tracking-wider mb-2"
                style="color: var(--tertiary)"
              >
                Dirección (Opcional)
              </label>
              <input
                id="direccion"
                type="text"
                placeholder="Ej: Av. San Martín 123"
                class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
              />
              <span
                class="block text-[10px] mt-1 pl-1"
                style="color: var(--quaternary)"
                >Completá solo si tenés un local o domicilio comercial.</span
              >
            </div>
          </div>

          <div class="space-y-4 pt-2">
            <h2
              class="text-sm font-bold text-emerald-400 uppercase tracking-wider pb-1.5"
              style="border-bottom: 1px solid var(--border-strongest)"
            >
              Credenciales de Acceso
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="email"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Correo Electrónico
                </label>
                <input
                  id="email"
                  type="email"
                  required
                  placeholder="tu@correo.com"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>

              <div>
                <label
                  for="email-confirmar"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Confirmar Correo Electrónico
                </label>
                <input
                  id="email-confirmar"
                  type="email"
                  required
                  placeholder="Repetí tu correo"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>

              <div>
                <label
                  for="password"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Contraseña
                </label>
                <input
                  id="password"
                  type="password"
                  required
                  placeholder="Mín. 8 caracteres (letras y números)"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
                <span
                  class="block text-[10px] mt-1 pl-1"
                  style="color: var(--quaternary)"
                  >Debe incluir al menos una letra y un número.</span
                >
              </div>

              <div>
                <label
                  for="password-confirmar"
                  class="block text-xs font-semibold uppercase tracking-wider mb-2"
                  style="color: var(--tertiary)"
                >
                  Confirmar Contraseña
                </label>
                <input
                  id="password-confirmar"
                  type="password"
                  required
                  placeholder="Repetí la contraseña"
                  class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>
            </div>
          </div>

          <button
            type="submit"
            class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3.5 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-colors active:scale-[0.99] mt-6 cursor-pointer"
          >
            Crear mi Cuenta
          </button>
        </form>
      </div>

      <div class="mt-6 text-center text-sm" style="color: var(--tertiary)">
        ¿Ya tenés una cuenta registrada?
        <a
          href="/login"
          class="text-emerald-400 font-semibold underline hover:text-emerald-300 ml-1 transition-colors"
        >
          Ingresá acá
        </a>
      </div>
    </div>

    <Footer showLinks={false} />
  </main>
</Layout>

<script>
  import {
    registrarUsuario,
    obtenerSesionActiva
  } from '../services/auth.service'
  import type { CategoriaRubro } from '../utils/constants'
  import { DOMINIOS_DESCARTABLES } from '../utils/constants'
  import { compressImageToBlob } from '../utils/images'
  import { mostrarError as mostrarErrorUI } from '../utils/ui'

  const sesion = await obtenerSesionActiva()
  if (sesion) {
    window.location.href = '/dashboard'
  } else {
    document.getElementById('loading-screen')?.classList.add('hidden')
  }

  const form = document.getElementById('form-registro') as HTMLFormElement
  const nombreInput = document.getElementById(
    'nombreEmprendimiento'
  ) as HTMLInputElement
  const categoriaSelect = document.getElementById(
    'categoria'
  ) as HTMLSelectElement
  const descripcionInput = document.getElementById(
    'descripcion'
  ) as HTMLTextAreaElement
  const whatsappInput = document.getElementById('whatsapp') as HTMLInputElement
  const ciudadSelect = document.getElementById('ciudad') as HTMLSelectElement
  const otraCiudadContainer = document.getElementById(
    'otra-ciudad-container'
  ) as HTMLDivElement
  const otraCiudadInput = document.getElementById(
    'otraCiudad'
  ) as HTMLInputElement
  const emailInput = document.getElementById('email') as HTMLInputElement
  const passwordInput = document.getElementById('password') as HTMLInputElement
  const passwordConfirmarInput = document.getElementById(
    'password-confirmar'
  ) as HTMLInputElement
  const charCounter = document.getElementById('char-counter') as HTMLSpanElement
  const alertaError = document.getElementById(
    'alerta-registro'
  ) as HTMLDivElement
  const alertaErrorTexto = document.getElementById(
    'alerta-registro-texto'
  ) as HTMLSpanElement

  const inputLogo = document.getElementById('fotoLogo') as HTMLInputElement
  const inputPortada = document.getElementById(
    'fotoPortada'
  ) as HTMLInputElement
  const previewLogo = document.getElementById('previewLogo') as HTMLImageElement
  const previewPortada = document.getElementById(
    'previewPortada'
  ) as HTMLImageElement
  const placeholderLogo = document.getElementById(
    'placeholderLogo'
  ) as HTMLDivElement
  const placeholderPortada = document.getElementById(
    'placeholderPortada'
  ) as HTMLDivElement

  let logoFile: File | Blob | undefined = undefined
  let portadaFile: File | Blob | undefined = undefined

  function mostrarError(msj: string) {
    mostrarErrorUI(alertaError, alertaErrorTexto, msj)
    window.scrollTo({ top: 0, behavior: 'smooth' })
  }

  inputLogo?.addEventListener('change', async () => {
    const file = inputLogo.files?.[0]
    if (!file) return
    try {
      const compressed = await compressImageToBlob(file)
      logoFile = compressed
      previewLogo.src = URL.createObjectURL(compressed)
      previewLogo.classList.remove('hidden')
      placeholderLogo.classList.add('hidden')
    } catch (err: unknown) {
      mostrarError(err instanceof Error ? err.message : 'Error desconocido')
      inputLogo.value = ''
      logoFile = undefined
    }
  })

  inputPortada?.addEventListener('change', async () => {
    const file = inputPortada.files?.[0]
    if (!file) return
    try {
      const compressed = await compressImageToBlob(file)
      portadaFile = compressed
      previewPortada.src = URL.createObjectURL(compressed)
      previewPortada.classList.remove('hidden')
      placeholderPortada.classList.add('hidden')
    } catch (err: unknown) {
      mostrarError(err instanceof Error ? err.message : 'Error desconocido')
      inputPortada.value = ''
      portadaFile = undefined
    }
  })

  ciudadSelect?.addEventListener('change', () => {
    if (ciudadSelect.value === 'otra') {
      otraCiudadContainer.classList.remove('hidden')
      otraCiudadInput.required = true
      otraCiudadInput.focus()
    } else {
      otraCiudadContainer.classList.add('hidden')
      otraCiudadInput.required = false
      otraCiudadInput.value = ''
    }
  })

  descripcionInput?.addEventListener('input', () => {
    const len = descripcionInput.value.length
    charCounter.textContent = `${len} / 150`
    charCounter.className =
      len >= 140
        ? 'text-[10px] text-amber-500 font-bold'
        : 'text-[10px] font-medium'
    if (len < 140) {
      charCounter.style.color = 'var(--tertiary)'
    }
  })

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()
    alertaError.classList.add('hidden')

    const nombre = nombreInput.value.trim()
    const categoria = categoriaSelect.value as CategoriaRubro
    const descripcion = descripcionInput.value.trim()
    const whatsapp = whatsappInput.value.trim().replace(/[^\d]/g, '')

    let ciudad = ciudadSelect.value
    if (ciudad === 'otra') {
      ciudad = otraCiudadInput.value.trim()
      if (!ciudad) {
        mostrarError('Por favor, ingresa el nombre de tu localidad.')
        return
      }
    }

    const email = emailInput.value.trim()
    const password = passwordInput.value
    const emailConfirmarInput = document.getElementById(
      'email-confirmar'
    ) as HTMLInputElement
    const emailConfirmar = emailConfirmarInput.value.trim()

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/
    if (!emailRegex.test(email)) {
      mostrarError('El formato del correo electrónico no es válido.')
      emailInput.focus()
      return
    }

    if (email !== emailConfirmar) {
      mostrarError('Los correos electrónicos no coinciden.')
      emailConfirmarInput.focus()
      return
    }

    const dominio = email.split('@')[1]?.toLowerCase()
    if (dominio && DOMINIOS_DESCARTABLES.includes(dominio)) {
      mostrarError(
        'No se permiten correos temporales o desechables. Usá un correo real.'
      )
      emailInput.focus()
      return
    }

    if (whatsapp.length < 8) {
      mostrarError(
        'Por favor, ingresa un número de WhatsApp válido (solo números con código de país).'
      )
      return
    }

    const tieneLetra = /[a-zA-Z]/.test(password)
    const tieneNumero = /\d/.test(password)
    if (password.length < 8 || !tieneLetra || !tieneNumero) {
      mostrarError(
        'La contraseña debe tener al menos 8 caracteres e incluir como mínimo una letra y un número.'
      )
      passwordInput.focus()
      return
    }

    const passwordConfirmar = passwordConfirmarInput.value
    if (password !== passwordConfirmar) {
      mostrarError('Las contraseñas no coinciden.')
      passwordConfirmarInput.focus()
      return
    }

    const direccionInput = document.getElementById(
      'direccion'
    ) as HTMLInputElement

    const loadingScreen = document.getElementById('loading-screen')
    if (loadingScreen) loadingScreen.classList.remove('hidden')

    const res = await registrarUsuario(email, password, {
      nombreEmprendimiento: nombre,
      categoria,
      descripcion,
      whatsapp,
      ciudad,
      direccion: direccionInput.value.trim(),
      sitioWeb: '',
      historia: '',
      fotoLogo: logoFile,
      fotoPortada: portadaFile
    })

    if (loadingScreen) loadingScreen.classList.add('hidden')

    if (res.success) {
      if (res.requireEmailConfirmation) {
        // Show success message and hide the form
        form.classList.add('hidden')
        alertaError.className =
          'text-xs p-4 rounded-2xl mb-6 flex items-start gap-2.5 bg-emerald-900/40 border border-emerald-500/50 text-emerald-400'
        alertaError.innerHTML = `<span class="font-bold">✓</span><span id="alerta-registro-texto">${res.message}</span>`
        alertaError.classList.remove('hidden')
        window.scrollTo({ top: 0, behavior: 'smooth' })
      } else {
        window.location.href = '/dashboard'
      }
    } else {
      mostrarError(res.message)
    }
  })
</script>
