---
import Layout from '../layouts/Layout.astro'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import { CATEGORIAS } from '../utils/constants'
---

<Layout title="Comercio Local - Cartelera Comunitaria">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 pt-8 pb-10 flex flex-col min-h-screen justify-between">
    <div>
      <Header />

      <div class="mb-6 flex gap-2 w-full max-w-lg mx-auto">
        <input
          id="buscador"
          type="text"
          placeholder="Busca un servicio o producto..."
          class="w-[75%] px-4 py-3.5 rounded-2xl text-base focus:outline-none focus:border-emerald-500 transition-colors placeholder-gray-500"
          style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
        />

        <div class="relative w-[25%]">
          <select
            id="filtro-rubro"
            class="w-full h-full pl-3 pr-6 py-3.5 rounded-2xl text-xs font-medium appearance-none focus:outline-none transition-all cursor-pointer text-ellipsis overflow-hidden whitespace-nowrap"
            style="background: var(--elevated); color: var(--secondary); border: 1px solid var(--border-strong)"
          >
            <option value="" disabled selected>Rubro</option>
            <option value="todas">Todos</option>
            {CATEGORIAS.map((cat) => (
              <option value={cat.value}>{cat.label}</option>
            ))}
          </select>
          <div
            id="icono-select"
            class="absolute inset-y-0 right-2 flex items-center pointer-events-none transition-colors"
            style="color: var(--tertiary)"
          >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>
        </div>
      </div>

      <div class="flex gap-4 mb-8 max-w-lg mx-auto">
        <button
          id="btn-servicios"
          class="flex-1 py-3.5 rounded-2xl border text-base font-semibold active:scale-[0.98] transition-all cursor-pointer"
          style="background: var(--elevated); color: var(--primary); border-color: var(--border-strong)"
        >
          Servicios y Oficios
        </button>
        <button
          id="btn-ventas"
          class="flex-1 py-3.5 rounded-2xl border text-base font-semibold active:scale-[0.98] transition-all cursor-pointer"
          style="background: var(--elevated); color: var(--primary); border-color: var(--border-strong)"
        >
          Ventas y Producción
        </button>
      </div>

      <div
        class="p-5 rounded-3xl border mb-3 text-center max-w-lg mx-auto backdrop-blur-md"
        style="background: var(--elevated-60); border-color: var(--border-strongest)"
      >
        <p class="text-sm leading-relaxed" style="color: var(--secondary)">
          Una cartelera digital para fomentar y facilitar el comercio local,
          de profesionales y emprendedores independientes de tu localidad.
          <a
            href="/nosotros"
            class="text-emerald-400 font-semibold underline hover:text-emerald-300 ml-1 transition-colors"
          >
            Conocé nuestras normas y propósito.
          </a>
        </p>
      </div>

      <div class="w-full pt-2 mb-8 max-w-lg mx-auto">
        <a
          href="/registro"
          class="block w-full text-center py-3.5 rounded-2xl text-base font-bold active:scale-[0.99] transition-all border cursor-pointer"
          style="background: var(--elevated); color: var(--primary); border-color: var(--border-strong)"
        >
          Crear una cuenta comercial o profesional
        </a>
      </div>

      <div class="mb-4">
        <h2
          id="titulo-feed"
          class="text-sm font-semibold tracking-wider uppercase px-1 pointer-events-none mb-4"
          style="color: var(--tertiary)"
        >
          Descubrí en tu localidad
        </h2>

        <div id="contenedor-feed" class="grid grid-cols-1 md:grid-cols-2 gap-6"></div>
      </div>
    </div>

    <Footer />
  </main>
</Layout>

<script>
  import {
    obtenerPublicaciones,
    obtenerCiudadesActivas,
    obtenerUltimaCiudad,
    guardarUltimaCiudad
  } from '../services/profile.service'
  import { obtenerSesionActiva } from '../services/auth.service'
  import { detectarLocalidad } from '../utils/geolocation'
  import { COLORES_CATEGORIAS, RESPALDOS_POR_RUBRO, CIUDADES_PREDEFINIDAS } from '../utils/constants'
  import type { CategoriaRubro } from '../utils/constants'
  import { escapeHtml, mezclarArray } from '../utils/formatters'

  const selectorCiudad = document.getElementById(
    'selector-ciudad-cabecera'
  ) as HTMLSelectElement
  const btnAuth = document.getElementById(
    'btn-auth-cabecera'
  ) as HTMLAnchorElement
  const buscador = document.getElementById('buscador') as HTMLInputElement
  const filtroRubro = document.getElementById('filtro-rubro') as HTMLSelectElement
  const iconoSelect = document.getElementById('icono-select') as HTMLDivElement
  const contenedorFeed = document.getElementById(
    'contenedor-feed'
  ) as HTMLDivElement

  const btnServicios = document.getElementById(
    'btn-servicios'
  ) as HTMLButtonElement
  const btnVentas = document.getElementById('btn-ventas') as HTMLButtonElement

  let tipoActivo: 'servicios' | 'ventas' | null = null

  const gruposCategorias = {
    servicios: ['oficios', 'jardineria', 'educacion', 'tecnologia'],
    ventas: ['comidas', 'artesanias', 'estetica', 'otros']
  }

  const [publicaciones, ciudadesActivas, sesion] = await Promise.all([
    obtenerPublicaciones(),
    obtenerCiudadesActivas(),
    obtenerSesionActiva()
  ])

  // DEBUG: mostrar datos iniciales en consola del navegador
  try {
    console.info('DEBUG publicaciones count:', publicaciones?.length)
    console.info('DEBUG ciudadesActivas:', ciudadesActivas)
  } catch (e) {
    // no-op
  }

  if (sesion && btnAuth) {
    btnAuth.href = '/dashboard'
    btnAuth.style.background = 'var(--elevated)'
    btnAuth.style.borderColor = 'var(--border-strong)'
    btnAuth.style.color = 'var(--primary)'
    btnAuth.innerHTML = '👤 Mi Perfil'
  }

  async function poblarSelectorLocalidades() {
    if (!selectorCiudad) return

    let ciudadSeleccionada = obtenerUltimaCiudad()

    if (!ciudadSeleccionada) {
      const detectada = await detectarLocalidad(ciudadesActivas)
      if (detectada) {
        guardarUltimaCiudad(detectada)
        ciudadSeleccionada = detectada
      } else {
        ciudadSeleccionada = ciudadesActivas[0] || CIUDADES_PREDEFINIDAS[0]
        guardarUltimaCiudad(ciudadSeleccionada)
      }
    }

    selectorCiudad.innerHTML = ''

    const ciudadFinal = ciudadSeleccionada
    ciudadesActivas.forEach((c) => {
      const opt = document.createElement('option')
      opt.value = c
      opt.textContent = `📍 ${c}`
      if (c === ciudadFinal) opt.selected = true
      selectorCiudad.appendChild(opt)
    })

    selectorCiudad.value = ciudadSeleccionada
  }

  function renderizarFeedCliente() {
    if (!contenedorFeed) return
    contenedorFeed.innerHTML = ''

    const ciudadActual = selectorCiudad ? selectorCiudad.value : ciudadesActivas[0] || ''
    const publicacionesFiltradas = publicaciones.filter(
      (pub) => pub.ciudad.toLowerCase() === ciudadActual.toLowerCase()
    )

    if (publicacionesFiltradas.length === 0) {
      contenedorFeed.innerHTML = `
        <div class="col-span-1 md:col-span-2 text-center py-12 p-6 rounded-3xl border"
          style="color: var(--quaternary); background: var(--elevated-40); border-color: var(--border-strongest)"
        >
          <span class="text-3xl block mb-2">📍</span>
          <p class="font-bold mb-1" style="color: var(--primary)">No hay comercios cargados en esta localidad.</p>
          <p class="text-xs" style="color: var(--tertiary)">Sé el primero de tu rubro en registrarse y aparecer acá.</p>
        </div>
      `
      return
    }

    publicacionesFiltradas.forEach((pub) => {
      const configColor =
        COLORES_CATEGORIAS[pub.categoria] || COLORES_CATEGORIAS.otros
      const nombre = escapeHtml(pub.nombreEmprendimiento)
      const descripcion = escapeHtml(pub.descripcion)
      const ciudad = escapeHtml(pub.ciudad)
      const categoria = pub.categoria
      const iniciales = nombre
        .split(' ')
        .map((n) => n[0])
        .join('')
        .slice(0, 2)
        .toUpperCase()
      const respaldos =
        RESPALDOS_POR_RUBRO[pub.categoria] || RESPALDOS_POR_RUBRO.otros

      const portadaValida = typeof pub.fotoPortada === 'string' && (pub.fotoPortada.startsWith('https://') || pub.fotoPortada.startsWith('data:image/'))
      const urlPortada = portadaValida ? escapeHtml(pub.fotoPortada as string) : respaldos.portada
      const logoValido = typeof pub.fotoLogo === 'string' && (pub.fotoLogo.startsWith('https://') || pub.fotoLogo.startsWith('data:image/'))
      const urlLogo = logoValido ? escapeHtml(pub.fotoLogo as string) : ''

      const htmlAvatar = urlLogo
        ? `<img src="${urlLogo}" alt="${nombre}" loading="lazy" class="w-full h-full object-cover shrink-0" />`
        : `<span class="font-bold text-base" style="color: var(--primary)">${iniciales}</span>`

      const card = document.createElement('div')
      card.className = `tarjeta-comercio p-5 rounded-3xl border-2 flex flex-col justify-between h-full`
      card.style.cssText = `background: rgba(${configColor.rgb}, 0.22); border-color: var(--border); color: var(--secondary)`
      card.setAttribute('data-nombre', pub.nombreEmprendimiento.toLowerCase())
      card.setAttribute('data-categoria', categoria)
      card.setAttribute('data-descripcion', pub.descripcion.toLowerCase())

      card.innerHTML = `
        <div class="flex flex-col grow">
          <div class="h-32 -mx-5 -mt-5 relative mb-6">
            <div class="rounded-t-3xl overflow-hidden h-full">
              <img src="${urlPortada}" alt="Portada" loading="lazy" class="w-full h-full object-cover filter brightness-[0.75]" />
              <div class="absolute inset-0 rounded-t-3xl" style="background: linear-gradient(to top, var(--overlay), transparent)"></div>
            </div>
            <div class="absolute -bottom-10 right-4 w-18 h-18 rounded-full overflow-hidden flex items-center justify-center shrink-0 shadow-lg" style="background: var(--surface); border: 4px solid var(--logo-border)">
              ${htmlAvatar}
            </div>
          </div>
          <div class="flex items-center justify-between gap-4 mb-2">
            <div class="overflow-hidden">
              <h3 class="font-bold text-base leading-tight truncate" style="color: var(--primary)">${nombre}</h3>
              <div class="flex items-center gap-1.5 mt-0.5">
                <span class="text-[10px] uppercase font-bold tracking-wider" style="color: var(--primary); opacity: 0.7">${categoria}</span>
                <span class="text-[10px]" style="color: var(--tertiary)">•</span>
                <span class="text-[10px] font-medium" style="color: var(--secondary)">📍 ${ciudad}</span>
              </div>
            </div>
          </div>
          <p class="text-xs leading-relaxed mb-5 line-clamp-3 h-10 overflow-hidden" style="color: var(--secondary)">
            ${descripcion}
          </p>
        </div>
        <a
          href="/perfil/${pub.slug}"
          class="w-full py-3 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 transition-colors mb-2 cursor-pointer"
          style="background: var(--button); border: 1px solid var(--border-stronger); color: var(--primary)"
        >
          📖 Ver Catálogo y Perfil
        </a>
        <a
          href="https://wa.me/${pub.whatsapp}?text=Hola%20${encodeURIComponent(pub.nombreEmprendimiento)},%20vi%20tu%20perfil%20en%20Comercio%20Local%20y%20me%20interesa%20lo%20que%20ofrecés."
          target="_blank"
          rel="noopener noreferrer"
          class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3 rounded-xl text-xs font-bold flex items-center justify-center gap-1.5 transition-colors active:scale-[0.99] cursor-pointer"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.948 0c3.179.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.907-11.89 11.907-2.013-.001-3.99-.51-5.772-1.482L0 24zm6.59-4.846c1.63.967 3.56 1.48 5.35 1.481 5.468 0 9.915-4.444 9.918-9.917.002-2.651-1.032-5.143-2.908-7.022C17.07 1.816 14.58 .78 11.948.78c-5.458 0-9.91 4.444-9.914 9.919-.001 1.889.499 3.73 1.447 5.362L2.456 21.23l5.191-1.362z" /></svg>
          Contactar por WhatsApp
        </a>
      `

      contenedorFeed.appendChild(card)
    })

    filtrarComercios()
  }

  function mezclarTarjetasEnPantalla() {
    const contenedor = document.getElementById('contenedor-feed')
    if (!contenedor) return
    const arrayTarjetas = Array.from(
      contenedor.querySelectorAll('.tarjeta-comercio')
    ) as HTMLDivElement[]
    mezclarArray(arrayTarjetas).forEach((tarjeta) => {
      contenedor.appendChild(tarjeta)
    })
  }

  function actualizarEstiloSelector() {
    const valor = filtroRubro.value

    filtroRubro.style.background = 'var(--elevated)'
    filtroRubro.style.color = 'var(--secondary)'
    filtroRubro.style.borderColor = 'var(--border-strong)'
    iconoSelect.style.color = 'var(--tertiary)'

    const configColor = COLORES_CATEGORIAS[valor as CategoriaRubro]
    if (valor && configColor) {
      filtroRubro.style.background = `rgba(${configColor.rgb}, 0.3)`
      filtroRubro.style.color = `rgb(${configColor.rgb})`
      filtroRubro.style.borderColor = `rgba(${configColor.rgb}, 0.6)`
      iconoSelect.style.color = `rgb(${configColor.rgb})`
    }
  }

  function filtrarComercios() {
    const textoBusqueda = buscador.value.toLowerCase().trim()
    const rubroSeleccionado = filtroRubro.value
    const tarjetas = contenedorFeed.querySelectorAll(
      '.tarjeta-comercio'
    ) as NodeListOf<HTMLDivElement>

    tarjetas.forEach((tarjeta) => {
      const nombreComercio = tarjeta.getAttribute('data-nombre') || ''
      const categoriaComercio = tarjeta.getAttribute('data-categoria') || ''
      const descripcionComercio =
        tarjeta.getAttribute('data-descripcion') || ''

      const coincideTexto =
        nombreComercio.includes(textoBusqueda) ||
        categoriaComercio.includes(textoBusqueda) ||
        descripcionComercio.includes(textoBusqueda)

      const coincideRubro =
        rubroSeleccionado === 'todas' ||
        rubroSeleccionado === '' ||
        categoriaComercio === rubroSeleccionado

      let coincideTipoGeneral = true
      if (tipoActivo) {
        coincideTipoGeneral =
          gruposCategorias[tipoActivo].includes(categoriaComercio)
      }

      if (coincideTexto && coincideRubro && coincideTipoGeneral) {
        tarjeta.style.display = 'block'
      } else {
        tarjeta.style.display = 'none'
      }
    })
  }

  function resetearEstilosBotones() {
    ;[btnServicios, btnVentas].forEach((btn) => {
      if (!btn) return
      btn.style.background = 'var(--elevated)'
      btn.style.color = 'var(--primary)'
      btn.style.borderColor = 'var(--border-strong)'
    })
  }

  function activarEstiloBoton(btn: HTMLButtonElement) {
    if (!btn) return
    btn.style.background = 'var(--primary)'
    btn.style.color = 'var(--surface)'
    btn.style.borderColor = 'var(--primary)'
  }

  btnServicios?.addEventListener('click', () => {
    mezclarTarjetasEnPantalla()
    if (tipoActivo === 'servicios') {
      tipoActivo = null
      resetearEstilosBotones()
    } else {
      tipoActivo = 'servicios'
      resetearEstilosBotones()
      activarEstiloBoton(btnServicios)
    }
    filtrarComercios()
  })

  btnVentas?.addEventListener('click', () => {
    mezclarTarjetasEnPantalla()
    if (tipoActivo === 'ventas') {
      tipoActivo = null
      resetearEstilosBotones()
    } else {
      tipoActivo = 'ventas'
      resetearEstilosBotones()
      activarEstiloBoton(btnVentas)
    }
    filtrarComercios()
  })

  buscador?.addEventListener('input', filtrarComercios)

  filtroRubro?.addEventListener('change', () => {
    mezclarTarjetasEnPantalla()
    actualizarEstiloSelector()
    filtrarComercios()
  })

  selectorCiudad?.addEventListener('change', () => {
    const seleccion = selectorCiudad.value
    guardarUltimaCiudad(seleccion)
    renderizarFeedCliente()
  })

  await poblarSelectorLocalidades()
  renderizarFeedCliente()
  mezclarTarjetasEnPantalla()
  actualizarEstiloSelector()
</script>
