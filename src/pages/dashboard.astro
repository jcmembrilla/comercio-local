---
import Layout from '../layouts/Layout.astro'
import LogoBrand from '../components/LogoBrand.astro'
import ConfirmModal from '../components/ConfirmModal.astro'
import { CATEGORIAS } from '../utils/constants'
---

<Layout title="Comercio Local - Mi Panel de Control">
  <main
    class="max-w-5xl mx-auto px-6 pt-10 pb-16 flex flex-col min-h-screen justify-between"
  >
    <div>
      <div
        class="flex items-center justify-between pb-4 mb-8"
        style="border-bottom: 1px solid var(--border-strongest)"
      >
        <div>
          <LogoBrand />
          <p
            id="subtitulo-bienvenida"
            class="text-[10px] mt-1"
            style="color: var(--tertiary)"
          >
            ¡Hola! Cargando tus datos...
          </p>
        </div>
        <div class="flex gap-3">
          <a
            href="/"
            class="text-xs px-4 py-2.5 rounded-xl transition-all flex items-center gap-1.5"
            style="background: var(--button); color: var(--secondary); border: 1px solid var(--border-strong);"
          >
            🔍 Ver Cartelera
          </a>
          <button
            id="btn-logout"
            class="text-xs bg-red-950/20 text-red-400 border border-red-950/80 px-4 py-2.5 rounded-xl hover:bg-red-950/40 hover:text-red-300 transition-all flex items-center gap-1.5 cursor-pointer font-bold shrink-0"
          >
            🚪 Salir
          </button>
        </div>
      </div>

      <div
        id="alerta-success"
        class="hidden text-xs p-4 rounded-2xl mb-6 flex items-start gap-2.5"
        style="background: var(--alert-success-bg); border: 1px solid var(--alert-success-border); color: var(--alert-success-text)"
      >
        <span class="text-emerald-400 font-bold">✓</span>
        <span id="alerta-success-texto">¡Cambios guardados con éxito!</span>
      </div>
      <div
        id="alerta-error"
        class="hidden text-xs p-4 rounded-2xl mb-6 flex items-start gap-2.5"
        style="background: var(--alert-error-bg); border: 1px solid var(--alert-error-border); color: var(--alert-error-text)"
      >
        <span class="text-red-400 font-bold">⚠️</span>
        <span id="alerta-error-texto">Ocurrió un error.</span>
      </div>

      <div class="space-y-8">
        <!-- BLOQUE 1: TARJETA DE PRESENTACIÓN -->
        <div>
          <p
            class="text-xs font-bold uppercase tracking-widest mb-3 px-1"
            style="color: var(--tertiary)"
          >
            Tu tarjeta de presentación
          </p>

          <div
            id="dashboard-hero"
            class="relative rounded-3xl overflow-hidden backdrop-blur-md"
            style="border: 2px solid var(--border)"
          >
            <div
              id="portada-wrapper"
              class="h-36 w-full overflow-hidden relative"
            >
              <img
                id="preview-portada-card"
                src=""
                alt="Portada"
                class="w-full h-full object-cover brightness-75"
              />
              <div
                class="absolute inset-0"
                style="background: linear-gradient(to top, var(--overlay), transparent)"
              >
              </div>
              <button
                id="btn-activar-edicion"
                class="absolute top-3 right-3 flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-xl transition-all cursor-pointer"
                style="background: var(--overlay); color: var(--primary); border: 1px solid var(--border)"
              >
                <svg
                  class="w-3.5 h-3.5"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10"
                  ></path>
                </svg>
                Editar Perfil
              </button>
            </div>

            <div id="modo-vista-perfil" class="px-5 pb-5 pt-14 relative">
              <div
                class="absolute -top-10 left-5 w-20 h-20 rounded-full overflow-hidden flex items-center justify-center font-bold text-xl shadow-xl"
                style="border: 4px solid var(--logo-border); background: var(--surface); color: var(--primary)"
              >
                <img
                  id="preview-logo-card"
                  src=""
                  alt="Logo"
                  class="hidden w-full h-full object-cover"
                />
                <span
                  id="iniciales-card"
                  class="font-bold text-lg"
                  style="color: var(--primary)"></span>
              </div>
              <div class="flex flex-col sm:flex-row justify-between gap-3">
                <div>
                  <h2
                    id="vista-nombre"
                    class="text-lg font-bold"
                    style="color: var(--primary)"
                  >
                  </h2>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span
                      id="vista-categoria"
                      class="text-xs font-semibold uppercase tracking-wider"
                    ></span>
                    <span style="color: var(--quaternary)">•</span>
                    <span
                      id="vista-ciudad"
                      class="text-xs"
                      style="color: var(--secondary)"></span>
                  </div>
                  <p
                    id="vista-descripcion"
                    class="text-xs mt-2 max-w-lg leading-relaxed"
                    style="color: var(--quaternary)"
                  >
                  </p>
                </div>
              </div>
            </div>

            <div
              id="panel-edicion"
              class="hidden px-5 pb-5 pt-14 relative"
              style="border-top: 1px solid var(--border-strongest)"
            >
              <div
                class="absolute -top-10 left-5 w-20 h-20 rounded-full overflow-hidden flex items-center justify-center font-bold text-xl shadow-xl pointer-events-none"
                style="border: 4px solid var(--logo-border); background: var(--surface); color: var(--primary)"
              >
                <img
                  id="preview-logo-edit"
                  src=""
                  alt="Logo"
                  class="hidden w-full h-full object-cover"
                />
                <span
                  id="iniciales-edit"
                  class="font-bold text-lg"
                  style="color: var(--primary)"></span>
              </div>

              <p
                class="text-xs font-bold text-emerald-400 uppercase tracking-wider mb-4"
              >
                Editando tu perfil
              </p>

              <form id="form-perfil" class="space-y-4">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label
                      for="nombre_emprendimiento"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Nombre del Emprendimiento
                    </label>
                    <input
                      id="nombre_emprendimiento"
                      type="text"
                      required
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    />
                  </div>
                  <div>
                    <label
                      for="categoria"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Rubro / Categoría
                    </label>
                    <select
                      id="categoria"
                      required
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors cursor-pointer"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    >
                      {
                        CATEGORIAS.map((cat) => (
                          <option value={cat.value}>{cat.label}</option>
                        ))
                      }
                    </select>
                  </div>
                </div>

                <div>
                  <div class="flex justify-between items-center mb-2">
                    <label
                      for="descripcion"
                      class="block text-xs font-semibold uppercase tracking-wider"
                      style="color: var(--quaternary)"
                    >
                      Descripción / Biografía
                    </label>
                    <span
                      id="char-counter"
                      class="text-[10px] font-medium"
                      style="color: var(--tertiary)">0 / 150</span
                    >
                  </div>
                  <textarea
                    id="descripcion"
                    required
                    maxlength="150"
                    rows="3"
                    class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors resize-none"
                    style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                  ></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Logo o Avatar
                    </label>
                    <label
                      for="foto_logo"
                      class="group flex items-center justify-center gap-2 w-full h-20 rounded-2xl border-2 border-dashed cursor-pointer transition-all relative overflow-hidden"
                      style="border-color: var(--border-strong); background: var(--surface)"
                    >
                      <img
                        id="preview-logo-input"
                        src=""
                        alt=""
                        class="hidden w-full h-full object-cover absolute inset-0 rounded-2xl"
                      />
                      <div
                        id="placeholder-logo"
                        class="flex items-center gap-2 pointer-events-none"
                      >
                        <svg
                          class="w-5 h-5 transition-colors"
                          style="color: var(--tertiary)"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="1.5"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
                          ></path>
                        </svg>
                        <span
                          class="text-[10px] transition-colors"
                          style="color: var(--tertiary)"
                          >Cambiar logo · Máx 2MB</span
                        >
                      </div>
                    </label>
                    <input
                      id="foto_logo"
                      type="file"
                      accept="image/*"
                      class="hidden"
                    />
                  </div>
                  <div>
                    <label
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Portada / Banner
                    </label>
                    <label
                      for="foto_portada"
                      class="group flex items-center justify-center gap-2 w-full h-20 rounded-2xl border-2 border-dashed cursor-pointer transition-all relative overflow-hidden"
                      style="border-color: var(--border-strong); background: var(--surface)"
                    >
                      <img
                        id="preview-portada-input"
                        src=""
                        alt=""
                        class="hidden w-full h-full object-cover absolute inset-0 rounded-2xl"
                      />
                      <div
                        id="placeholder-portada"
                        class="flex items-center gap-2 pointer-events-none"
                      >
                        <svg
                          class="w-5 h-5 transition-colors"
                          style="color: var(--tertiary)"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="1.5"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                          ></path>
                        </svg>
                        <span
                          class="text-[10px] transition-colors"
                          style="color: var(--tertiary)"
                          >Cambiar portada · Máx 2MB</span
                        >
                      </div>
                    </label>
                    <input
                      id="foto_portada"
                      type="file"
                      accept="image/*"
                      class="hidden"
                    />
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label
                      for="whatsapp"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      WhatsApp de Contacto
                    </label>
                    <input
                      id="whatsapp"
                      type="tel"
                      required
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    />
                  </div>
                  <div>
                    <label
                      for="ciudad"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Localidad / Ciudad
                    </label>
                    <input
                      id="ciudad"
                      type="text"
                      required
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    />
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div>
                    <label
                      for="direccion"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Dirección (Opcional)
                    </label>
                    <input
                      id="direccion"
                      type="text"
                      placeholder="Ej: Av. San Martín 123"
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    />
                    <span
                      class="block text-[10px] mt-1 pl-1"
                      style="color: var(--quaternary)"
                      >Completá solo si tenés un local comercial.</span
                    >
                  </div>
                  <div>
                    <label
                      for="sitio_web"
                      class="block text-xs font-semibold uppercase tracking-wider mb-2"
                      style="color: var(--quaternary)"
                    >
                      Sitio Web / Red Social
                    </label>
                    <input
                      id="sitio_web"
                      type="url"
                      placeholder="Ej: https://instagram.com/tu_cuenta"
                      class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
                      style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                    />
                  </div>
                </div>

                <div>
                  <div class="flex justify-between items-center mb-2">
                    <label
                      for="historia"
                      class="block text-xs font-semibold uppercase tracking-wider"
                      style="color: var(--quaternary)"
                    >
                      Historia / Sobre vos (Opcional)
                    </label>
                    <span
                      id="char-counter-historia"
                      class="text-[10px] font-medium"
                      style="color: var(--tertiary)">0 / 500</span
                    >
                  </div>
                  <textarea
                    id="historia"
                    maxlength="500"
                    rows="3"
                    placeholder="Contá cómo trabajás, tu tradición, qué inspiró tu emprendimiento..."
                    class="w-full px-4 py-3 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors resize-none"
                    style="background: var(--surface); color: var(--primary); border: 1px solid var(--border-strong)"
                  ></textarea>
                </div>

                <div class="flex gap-3 pt-2">
                  <button
                    type="submit"
                    class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white py-3 rounded-2xl text-sm font-bold transition-all active:scale-[0.99] cursor-pointer"
                  >
                    Guardar Cambios
                  </button>
                  <button
                    type="button"
                    id="btn-cancelar-edicion-perfil"
                    class="px-5 py-3 rounded-2xl text-sm font-bold transition-all cursor-pointer"
                    style="background: var(--elevated); color: var(--secondary); border: 1px solid var(--border-strong)"
                  >
                    Cancelar
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- BLOQUE 2: PANEL DE PUBLICACIONES -->
        <div
          class="p-6 rounded-3xl backdrop-blur-md"
          style="background: var(--elevated-60); border: 1px solid var(--border-strongest)"
        >
          <h2
            class="text-base font-bold text-emerald-400 uppercase tracking-wider mb-1 flex items-center gap-2.5"
          >
            <svg
              class="w-5 h-5 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            Panel de Publicaciones
          </h2>
          <p class="text-xs mb-5" style="color: var(--tertiary)">
            En este panel podés agregar algunos de tus trabajos para que los
            vean tus clientes.
          </p>

          <div
            id="hint-foto-opcional"
            class="hidden mb-4 bg-indigo-950/30 border border-indigo-500/20 text-indigo-300 text-xs p-3 rounded-xl flex items-start gap-2"
          >
            <svg
              class="w-4 h-4 shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"
              ></path>
            </svg>
            <span
              >Para tu rubro, la foto es <strong>opcional</strong>. Podés
              publicar solo con una descripción de lo que hacés.</span
            >
          </div>

          <form
            id="form-producto"
            data-mode="add"
            data-editing-id=""
            class="space-y-4 p-4 rounded-2xl mb-6"
            style="background: var(--overlay); border: 1px solid var(--border)"
          >
            <div class="flex justify-between items-center">
              <p
                id="form-producto-titulo"
                class="text-xs font-bold"
                style="color: var(--secondary)"
              >
                Nueva publicación:
              </p>
              <button
                type="button"
                id="btn-cancelar-edicion"
                class="hidden text-[10px] px-2 py-1 rounded-lg cursor-pointer"
                style="background: var(--elevated); color: var(--tertiary); border: 1px solid var(--border-strong)"
              >
                Cancelar Edición
              </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  for="prod-titulo"
                  class="block text-[11px] font-semibold uppercase tracking-wider mb-1.5"
                  style="color: var(--quaternary)"
                >
                  Título *
                </label>
                <input
                  id="prod-titulo"
                  type="text"
                  required
                  placeholder="Ej: Docena de empanadas o Instalación eléctrica"
                  class="w-full px-3 py-2.5 rounded-xl text-xs focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--button); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>
              <div>
                <label
                  for="prod-precio"
                  class="block text-[11px] font-semibold uppercase tracking-wider mb-1.5"
                  style="color: var(--quaternary)"
                >
                  Precio ($ARS, Opcional)
                </label>
                <input
                  id="prod-precio"
                  type="number"
                  placeholder="Ej: 4500 (Dejar vacío para omitir)"
                  class="w-full px-3 py-2.5 rounded-xl text-xs focus:outline-none focus:border-emerald-500 transition-colors"
                  style="background: var(--button); color: var(--primary); border: 1px solid var(--border-strong)"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              <div>
                <label
                  id="label-prod-foto"
                  class="block text-[11px] font-semibold uppercase tracking-wider mb-1.5"
                  style="color: var(--quaternary)"
                >
                  Foto del trabajo
                </label>
                <label
                  for="prod-foto-file"
                  class="group flex items-center justify-center gap-2 w-full h-24 rounded-xl border-2 border-dashed cursor-pointer transition-all relative overflow-hidden"
                  style="border-color: var(--border-strong); background: var(--button)"
                >
                  <img
                    id="preview-prod-foto"
                    src=""
                    alt=""
                    class="hidden w-full h-full object-cover absolute inset-0 rounded-xl"
                  />
                  <div
                    id="placeholder-prod-foto"
                    class="flex flex-col items-center gap-1 pointer-events-none"
                  >
                    <svg
                      class="w-6 h-6 transition-colors"
                      style="color: var(--tertiary)"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="1.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"
                      ></path>
                    </svg>
                    <span
                      id="prod-foto-hint"
                      class="text-[9px] transition-colors"
                      style="color: var(--tertiary)">Subir foto · Máx 2MB</span
                    >
                  </div>
                </label>
                <input
                  id="prod-foto-file"
                  type="file"
                  accept="image/*"
                  class="hidden"
                />
              </div>

              <div>
                <div class="flex justify-between items-center mb-1.5">
                  <label
                    for="prod-desc"
                    class="block text-[11px] font-semibold uppercase tracking-wider"
                    style="color: var(--quaternary)"
                  >
                    Descripción *
                  </label>
                  <span
                    id="char-counter-prod"
                    class="text-[9px] font-medium"
                    style="color: var(--tertiary)">0 / 120</span
                  >
                </div>
                <textarea
                  id="prod-desc"
                  required
                  maxlength="120"
                  rows="4"
                  placeholder="Describí qué incluye este trabajo o servicio..."
                  class="w-full px-3 py-2.5 rounded-xl text-xs focus:outline-none focus:border-emerald-500 transition-colors resize-none"
                  style="background: var(--button); color: var(--primary); border: 1px solid var(--border-strong)"
                ></textarea>
              </div>
            </div>

            <button
              type="submit"
              id="btn-submit-producto"
              class="w-full py-2.5 rounded-xl text-xs font-bold transition-all active:scale-[0.99] cursor-pointer"
              style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
            >
              + Publicar
            </button>
          </form>

          <div>
            <p
              class="text-xs font-bold uppercase tracking-wider mb-3"
              style="color: var(--quaternary)"
            >
              Tus Publicaciones
            </p>
            <div
              id="lista-productos"
              class="space-y-2.5 max-h-80 overflow-y-auto pr-1"
            >
            </div>
          </div>
        </div>

        <!-- BLOQUE 3: PREVISUALIZACIÓN CATÁLOGO -->
        <div>
          <p
            class="text-xs font-bold uppercase tracking-widest mb-3 px-1"
            style="color: var(--tertiary)"
          >
            Previsualización de tu catálogo público
          </p>
          <div
            id="contenedor-preview-catalogo"
            class="grid grid-cols-1 sm:grid-cols-2 gap-4"
          >
          </div>
        </div>
      </div>
    </div>

    <footer
      class="w-full pt-12 pb-2 text-center text-xs tracking-wide"
      style="color: var(--quaternary)"
    >
      <p>&copy; 2026 Comercio Local</p>
    </footer>
    <ConfirmModal />
  </main>
</Layout>

<script>
  import {
    obtenerSesionActiva,
    cerrarSesion,
    actualizarPerfil,
    agregarProducto,
    editarProducto,
    eliminarProducto
  } from '../utils/storage'
  import {
    COLORES_CATEGORIAS,
    RESPALDOS_POR_RUBRO,
    RUBROS_FOTO_OPCIONAL
  } from '../utils/constants'
  import type { CategoriaRubro } from '../utils/constants'
  import { leerArchivoBase64 } from '../utils/images'
  import { mostrarExito, mostrarError as mostrarErrorUI } from '../utils/ui'
  import { calcularIniciales, escapeHtml } from '../utils/formatters'

  let sesion = await obtenerSesionActiva()
  if (!sesion) window.location.href = '/login'

  let categoriaColor = '82, 82, 91'

  const subBienvenida = document.getElementById(
    'subtitulo-bienvenida'
  ) as HTMLParagraphElement
  const btnLogout = document.getElementById('btn-logout') as HTMLButtonElement
  const alertaSuccess = document.getElementById(
    'alerta-success'
  ) as HTMLDivElement
  const alertaSuccessT = document.getElementById(
    'alerta-success-texto'
  ) as HTMLSpanElement
  const alertaError = document.getElementById('alerta-error') as HTMLDivElement
  const alertaErrorT = document.getElementById(
    'alerta-error-texto'
  ) as HTMLSpanElement
  const btnActivarEdicion = document.getElementById(
    'btn-activar-edicion'
  ) as HTMLButtonElement
  const modoVistaPerfil = document.getElementById(
    'modo-vista-perfil'
  ) as HTMLDivElement
  const panelEdicion = document.getElementById(
    'panel-edicion'
  ) as HTMLDivElement
  const btnCancelarEdPerfil = document.getElementById(
    'btn-cancelar-edicion-perfil'
  ) as HTMLButtonElement
  const previewPortadaCard = document.getElementById(
    'preview-portada-card'
  ) as HTMLImageElement
  const previewLogoCard = document.getElementById(
    'preview-logo-card'
  ) as HTMLImageElement
  const inicialesCard = document.getElementById(
    'iniciales-card'
  ) as HTMLSpanElement
  const vistaNombre = document.getElementById('vista-nombre') as HTMLElement
  const vistaCategoria = document.getElementById(
    'vista-categoria'
  ) as HTMLElement
  const vistaCiudad = document.getElementById('vista-ciudad') as HTMLElement
  const vistaDesc = document.getElementById('vista-descripcion') as HTMLElement
  const formPerfil = document.getElementById('form-perfil') as HTMLFormElement
  const inputNombre = document.getElementById(
    'nombre_emprendimiento'
  ) as HTMLInputElement
  const selectCategoria = document.getElementById(
    'categoria'
  ) as HTMLSelectElement
  const textareaDesc = document.getElementById(
    'descripcion'
  ) as HTMLTextAreaElement
  const inputWhatsapp = document.getElementById('whatsapp') as HTMLInputElement
  const inputCiudad = document.getElementById('ciudad') as HTMLInputElement
  const inputDireccion = document.getElementById(
    'direccion'
  ) as HTMLInputElement
  const inputSitioWeb = document.getElementById('sitio_web') as HTMLInputElement
  const textareaHistoria = document.getElementById(
    'historia'
  ) as HTMLTextAreaElement
  const charCounter = document.getElementById('char-counter') as HTMLSpanElement
  const charCounterHistoria = document.getElementById(
    'char-counter-historia'
  ) as HTMLSpanElement
  const inputLogo = document.getElementById('foto_logo') as HTMLInputElement
  const inputPortada = document.getElementById(
    'foto_portada'
  ) as HTMLInputElement
  const previewLogoInput = document.getElementById(
    'preview-logo-input'
  ) as HTMLImageElement
  const previewPortadaInput = document.getElementById(
    'preview-portada-input'
  ) as HTMLImageElement
  const placeholderLogo = document.getElementById(
    'placeholder-logo'
  ) as HTMLDivElement
  const placeholderPortada = document.getElementById(
    'placeholder-portada'
  ) as HTMLDivElement
  const previewLogoEdit = document.getElementById(
    'preview-logo-edit'
  ) as HTMLImageElement
  const inicialesEdit = document.getElementById(
    'iniciales-edit'
  ) as HTMLSpanElement
  const formProducto = document.getElementById(
    'form-producto'
  ) as HTMLFormElement
  const formProductoTit = document.getElementById(
    'form-producto-titulo'
  ) as HTMLParagraphElement
  const prodTitulo = document.getElementById('prod-titulo') as HTMLInputElement
  const prodPrecio = document.getElementById('prod-precio') as HTMLInputElement
  const prodDesc = document.getElementById('prod-desc') as HTMLTextAreaElement
  const charCounterProd = document.getElementById(
    'char-counter-prod'
  ) as HTMLSpanElement
  const btnSubmitProducto = document.getElementById(
    'btn-submit-producto'
  ) as HTMLButtonElement
  const btnCancelarEdicion = document.getElementById(
    'btn-cancelar-edicion'
  ) as HTMLButtonElement
  const listaProductos = document.getElementById(
    'lista-productos'
  ) as HTMLDivElement
  const hintFotoOpcional = document.getElementById(
    'hint-foto-opcional'
  ) as HTMLDivElement
  const labelProdFoto = document.getElementById(
    'label-prod-foto'
  ) as HTMLLabelElement
  const prodFotoHint = document.getElementById(
    'prod-foto-hint'
  ) as HTMLSpanElement
  const previewProdFoto = document.getElementById(
    'preview-prod-foto'
  ) as HTMLImageElement
  const placeholderProdFoto = document.getElementById(
    'placeholder-prod-foto'
  ) as HTMLDivElement
  const inputProdFotoFile = document.getElementById(
    'prod-foto-file'
  ) as HTMLInputElement
  const contenedorCatalogo = document.getElementById(
    'contenedor-preview-catalogo'
  ) as HTMLDivElement

  let base64Logo = ''
  let base64Portada = ''
  let base64ProdFoto = ''

  function mostrarError(msj: string) {
    mostrarErrorUI(alertaError, alertaErrorT, msj, alertaSuccess)
  }

  if (sesion) {
    subBienvenida.textContent = `Gestionando el perfil de ${sesion.email}`
    inputNombre.value = sesion.nombre_emprendimiento
    selectCategoria.value = sesion.categoria
    textareaDesc.value = sesion.descripcion
    inputWhatsapp.value = sesion.whatsapp
    inputCiudad.value = sesion.ciudad
    inputDireccion.value = sesion.direccion || ''
    inputSitioWeb.value = sesion.sitio_web || ''
    textareaHistoria.value = sesion.historia || ''
    charCounterHistoria.textContent = `${(sesion.historia || '').length} / 500`
    charCounter.textContent = `${sesion.descripcion.length} / 150`
    base64Logo = sesion.fotoLogo || ''
    base64Portada = sesion.fotoPortada || ''
    actualizarModoVista()
    actualizarHintRubro()
    renderizarCatalogo()
    renderizarPreviewCatalogo()
  }

  function actualizarModoVista() {
    if (!sesion) return
    const respaldos =
      RESPALDOS_POR_RUBRO[sesion.categoria] || RESPALDOS_POR_RUBRO.otros
    const colores =
      COLORES_CATEGORIAS[sesion.categoria] || COLORES_CATEGORIAS.otros
    const iniciales = calcularIniciales(sesion.nombre_emprendimiento)

    categoriaColor = colores.rgb
    const hero = document.getElementById('dashboard-hero') as HTMLDivElement
    if (hero)
      hero.style.cssText = `background: rgba(${colores.rgb}, 0.22); border: 2px solid var(--border)`

    previewPortadaCard.src = sesion.fotoPortada || respaldos.portada

    if (sesion.fotoLogo) {
      previewLogoCard.src = sesion.fotoLogo
      previewLogoCard.classList.remove('hidden')
      inicialesCard.textContent = ''
    } else {
      previewLogoCard.classList.add('hidden')
      inicialesCard.textContent = iniciales
    }

    vistaNombre.textContent = sesion.nombre_emprendimiento
    vistaCategoria.textContent = sesion.categoria.toUpperCase()
    vistaCategoria.className = `text-xs font-semibold uppercase tracking-wider ${colores.text}`
    const dirText = sesion.direccion ? ` • ${sesion.direccion}` : ''
    vistaCiudad.textContent = `📍 ${sesion.ciudad}${dirText}`
    vistaDesc.textContent = sesion.descripcion

    const logoSrc = base64Logo || sesion.fotoLogo || ''
    if (logoSrc) {
      previewLogoInput.src = logoSrc
      previewLogoInput.classList.remove('hidden')
      placeholderLogo.classList.add('hidden')
      previewLogoEdit.src = logoSrc
      previewLogoEdit.classList.remove('hidden')
      inicialesEdit.textContent = ''
    } else {
      previewLogoEdit.classList.add('hidden')
      inicialesEdit.textContent = iniciales
    }
    const portadaSrc = base64Portada || sesion.fotoPortada || ''
    if (portadaSrc) {
      previewPortadaInput.src = portadaSrc
      previewPortadaInput.classList.remove('hidden')
      placeholderPortada.classList.add('hidden')
    }
  }

  btnActivarEdicion?.addEventListener('click', () => {
    modoVistaPerfil.classList.add('hidden')
    panelEdicion.classList.remove('hidden')
    panelEdicion.scrollIntoView({ behavior: 'smooth', block: 'nearest' })
  })

  btnCancelarEdPerfil?.addEventListener('click', () => {
    panelEdicion.classList.add('hidden')
    modoVistaPerfil.classList.remove('hidden')
    base64Logo = sesion?.fotoLogo || ''
    base64Portada = sesion?.fotoPortada || ''
    actualizarModoVista()
  })

  inputLogo?.addEventListener('change', async () => {
    const file = inputLogo.files?.[0]
    if (!file) return
    try {
      base64Logo = await leerArchivoBase64(file)
      previewLogoInput.src = base64Logo
      previewLogoInput.classList.remove('hidden')
      placeholderLogo.classList.add('hidden')
      previewLogoEdit.src = base64Logo
      previewLogoEdit.classList.remove('hidden')
      inicialesEdit.textContent = ''
    } catch (e: unknown) {
      mostrarError(e instanceof Error ? e.message : 'Error desconocido')
      inputLogo.value = ''
      base64Logo = sesion?.fotoLogo || ''
    }
  })

  inputPortada?.addEventListener('change', async () => {
    const file = inputPortada.files?.[0]
    if (!file) return
    try {
      base64Portada = await leerArchivoBase64(file)
      previewPortadaInput.src = base64Portada
      previewPortadaInput.classList.remove('hidden')
      placeholderPortada.classList.add('hidden')
      previewPortadaCard.src = base64Portada
    } catch (e: unknown) {
      mostrarError(e instanceof Error ? e.message : 'Error desconocido')
      inputPortada.value = ''
      base64Portada = sesion?.fotoPortada || ''
    }
  })

  formPerfil?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!sesion) return
    const res = await actualizarPerfil(sesion.id, {
      nombre_emprendimiento: inputNombre.value.trim(),
      categoria: selectCategoria.value as CategoriaRubro,
      descripcion: textareaDesc.value.trim(),
      whatsapp: inputWhatsapp.value.trim().replace(/[^\d]/g, ''),
      ciudad: inputCiudad.value.trim(),
      direccion: inputDireccion.value.trim(),
      sitio_web: inputSitioWeb.value.trim(),
      historia: textareaHistoria.value.trim(),
      fotoLogo: base64Logo,
      fotoPortada: base64Portada
    })
    if (res.success) {
      sesion = (await obtenerSesionActiva())!
      panelEdicion.classList.add('hidden')
      modoVistaPerfil.classList.remove('hidden')
      actualizarModoVista()
      actualizarHintRubro()
      mostrarExito(alertaSuccess, alertaSuccessT, res.message, alertaError)
    } else mostrarError(res.message)
  })

  textareaDesc?.addEventListener('input', () => {
    charCounter.textContent = `${textareaDesc.value.length} / 150`
  })

  textareaHistoria?.addEventListener('input', () => {
    charCounterHistoria.textContent = `${textareaHistoria.value.length} / 500`
  })

  function actualizarHintRubro() {
    if (!sesion) return
    const esOpcional = RUBROS_FOTO_OPCIONAL.includes(sesion.categoria)
    hintFotoOpcional.classList.toggle('hidden', !esOpcional)
    labelProdFoto.textContent = esOpcional
      ? 'Foto del trabajo (Opcional)'
      : 'Foto del trabajo *'
    if (prodFotoHint) prodFotoHint.textContent = 'Subir foto · Máx 2MB'
  }

  inputProdFotoFile?.addEventListener('change', async () => {
    const file = inputProdFotoFile.files?.[0]
    if (!file) return
    try {
      base64ProdFoto = await leerArchivoBase64(file)
      previewProdFoto.src = base64ProdFoto
      previewProdFoto.classList.remove('hidden')
      placeholderProdFoto.classList.add('hidden')
    } catch (e: unknown) {
      mostrarError(e instanceof Error ? e.message : 'Error desconocido')
      inputProdFotoFile.value = ''
      base64ProdFoto = ''
    }
  })

  prodDesc?.addEventListener('input', () => {
    charCounterProd.textContent = `${prodDesc.value.length} / 120`
  })

  formProducto?.addEventListener('submit', async (e) => {
    e.preventDefault()
    if (!sesion) return
    const mode = formProducto.getAttribute('data-mode')
    const editingId = formProducto.getAttribute('data-editing-id') || ''
    const datos = {
      titulo: prodTitulo.value.trim(),
      precio: prodPrecio.value ? parseFloat(prodPrecio.value) : undefined,
      foto: base64ProdFoto,
      descripcion: prodDesc.value.trim()
    }
    if (mode === 'edit' && editingId) {
      const res = await editarProducto(sesion.id, editingId, datos)
      if (res.success) {
        sesion = (await obtenerSesionActiva())!
        resetFormProducto()
        mostrarExito(alertaSuccess, alertaSuccessT, res.message, alertaError)
        renderizarCatalogo()
        renderizarPreviewCatalogo()
      } else mostrarError(res.message)
    } else {
      const res = await agregarProducto(sesion.id, datos)
      if (res.success) {
        sesion = (await obtenerSesionActiva())!
        resetFormProducto()
        mostrarExito(alertaSuccess, alertaSuccessT, res.message, alertaError)
        renderizarCatalogo()
        renderizarPreviewCatalogo()
      } else mostrarError(res.message)
    }
  })

  btnCancelarEdicion?.addEventListener('click', resetFormProducto)

  function resetFormProducto() {
    formProducto.reset()
    formProducto.setAttribute('data-mode', 'add')
    formProducto.setAttribute('data-editing-id', '')
    formProductoTit.textContent = 'Nueva publicación:'
    btnSubmitProducto.textContent = '+ Publicar'
    btnSubmitProducto.className =
      'w-full py-2.5 rounded-xl text-xs font-bold transition-all active:scale-[0.99] cursor-pointer'
    btnSubmitProducto.style.cssText =
      'background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)'
    btnCancelarEdicion.classList.add('hidden')
    charCounterProd.textContent = '0 / 120'
    base64ProdFoto = ''
    if (previewProdFoto) {
      previewProdFoto.src = ''
      previewProdFoto.classList.add('hidden')
    }
    if (placeholderProdFoto) placeholderProdFoto.classList.remove('hidden')
    if (inputProdFotoFile) inputProdFotoFile.value = ''
  }

  btnLogout?.addEventListener('click', async () => {
    await cerrarSesion()
    window.location.href = '/login'
  })

  function mostrarModalConfirmacion(mensaje: string): Promise<boolean> {
    return new Promise((resolve) => {
      const modal = document.getElementById('confirm-modal') as HTMLDivElement
      const messageEl = document.getElementById(
        'confirm-modal-message'
      ) as HTMLParagraphElement
      const acceptBtn = document.getElementById(
        'confirm-modal-accept'
      ) as HTMLButtonElement
      const cancelBtn = document.getElementById(
        'confirm-modal-cancel'
      ) as HTMLButtonElement
      if (!modal || !messageEl || !acceptBtn || !cancelBtn) {
        resolve(true)
        return
      }

      messageEl.textContent = mensaje
      modal.classList.remove('hidden')

      const cleanup = () => {
        modal.classList.add('hidden')
        acceptBtn.removeEventListener('click', onAccept)
        cancelBtn.removeEventListener('click', onCancel)
      }
      const onAccept = () => {
        cleanup()
        resolve(true)
      }
      const onCancel = () => {
        cleanup()
        resolve(false)
      }

      acceptBtn.addEventListener('click', onAccept)
      cancelBtn.addEventListener('click', onCancel)
    })
  }

  function renderizarCatalogo() {
    if (!listaProductos || !sesion) return
    listaProductos.innerHTML = ''
    if (sesion.productos.length === 0) {
      listaProductos.innerHTML = `<div class="text-center py-6 text-xs italic rounded-2xl" style="color: var(--tertiary); border: 1px dashed var(--border-strong)">Aún no tenés publicaciones. ¡Agregá la primera arriba!</div>`
      return
    }
    sesion.productos.forEach((prod) => {
      const item = document.createElement('div')
      item.className =
        'flex items-center justify-between gap-4 p-3.5 rounded-2xl text-xs backdrop-blur-sm transition-all'
      item.style.cssText =
        'background: var(--overlay); border: 1px solid var(--border-strongest)'
      const titulo = escapeHtml(prod.titulo)
      const desc = escapeHtml(prod.descripcion)
      const precio = prod.precio
      const fotoValida =
        prod.foto &&
        (prod.foto.startsWith('https://') ||
          prod.foto.startsWith('data:image/'))
      const fotoUrl = fotoValida ? escapeHtml(prod.foto!) : ''
      const priceText =
        precio != null
          ? `<span class="bg-emerald-950/40 border border-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded-lg font-bold shrink-0">$${precio}</span>`
          : ''
      const imgHtml = fotoUrl
        ? `<img src="${fotoUrl}" alt="${titulo}" loading="lazy" class="w-12 h-12 object-cover rounded-xl shrink-0" style="border: 1px solid var(--border)" />`
        : `<div class="w-12 h-12 rounded-xl shrink-0 flex items-center justify-center text-lg" style="border: 1px solid var(--border-strong); background: var(--elevated); color: var(--quaternary)">📄</div>`
      const prodId = escapeHtml(String(prod.id))
      item.innerHTML = `
        <div class="flex items-center gap-3 overflow-hidden grow">
          ${imgHtml}
          <div class="overflow-hidden space-y-0.5">
            <div class="flex items-center gap-2"><p class="font-bold truncate" style="color: var(--primary)">${titulo}</p>${priceText}</div>
            <p class="text-[10px] truncate" style="color: var(--quaternary)">${desc}</p>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <button data-prod-id="${prodId}" class="btn-editar text-[10px] bg-emerald-950/20 text-emerald-400 border border-emerald-900/60 px-2.5 py-1.5 rounded-lg hover:bg-emerald-950/40 transition-colors font-semibold cursor-pointer">Editar</button>
          <button data-prod-id="${prodId}" class="btn-eliminar text-[10px] bg-red-950/20 text-red-400 border border-red-950/80 px-2.5 py-1.5 rounded-lg hover:bg-red-950/40 transition-colors font-semibold cursor-pointer">Borrar</button>
        </div>`
      listaProductos.appendChild(item)
    })
    listaProductos.querySelectorAll('.btn-editar').forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const id = (e.currentTarget as HTMLButtonElement).getAttribute(
          'data-prod-id'
        )
        if (id && sesion) {
          const prod = sesion.productos.find((p) => String(p.id) === String(id))
          if (prod) {
            prodTitulo.value = prod.titulo
            prodPrecio.value = prod.precio != null ? String(prod.precio) : ''
            prodDesc.value = prod.descripcion
            charCounterProd.textContent = `${prod.descripcion.length} / 120`
            base64ProdFoto = prod.foto || ''
            if (base64ProdFoto) {
              previewProdFoto.src = base64ProdFoto
              previewProdFoto.classList.remove('hidden')
              placeholderProdFoto.classList.add('hidden')
            }
            formProducto.setAttribute('data-mode', 'edit')
            formProducto.setAttribute('data-editing-id', String(id))
            formProductoTit.textContent = '✏️ Editando publicación:'
            btnSubmitProducto.textContent = '✏️ Guardar Cambios'
            btnSubmitProducto.className =
              'w-full bg-emerald-600 hover:bg-emerald-500 text-white py-2.5 rounded-xl text-xs font-bold transition-all active:scale-[0.99] cursor-pointer'
            btnSubmitProducto.style.cssText = ''
            btnCancelarEdicion.classList.remove('hidden')
            formProducto.scrollIntoView({ behavior: 'smooth', block: 'center' })
          }
        }
      })
    })
    listaProductos.querySelectorAll('.btn-eliminar').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        const id = (e.currentTarget as HTMLButtonElement).getAttribute(
          'data-prod-id'
        )
        if (!id || !sesion) return

        const confirmado = await mostrarModalConfirmacion(
          '¿Eliminar esta publicación de tu perfil?'
        )
        if (!confirmado) return

        const res = await eliminarProducto(sesion.id, id)
        if (res.success) {
          sesion = (await obtenerSesionActiva())!
          renderizarCatalogo()
          renderizarPreviewCatalogo()
          mostrarExito(alertaSuccess, alertaSuccessT, res.message, alertaError)
          if (
            String(formProducto.getAttribute('data-editing-id')) === String(id)
          )
            resetFormProducto()
        } else mostrarError(res.message)
      })
    })
  }

  function renderizarPreviewCatalogo() {
    if (!contenedorCatalogo || !sesion) return
    contenedorCatalogo.innerHTML = ''
    if (sesion.productos.length === 0) {
      contenedorCatalogo.innerHTML = `<div class="col-span-2 text-center py-6 text-xs italic rounded-2xl p-4" style="color: var(--tertiary); border: 2px solid var(--border); background: rgba(${categoriaColor}, 0.18)">Cargá publicaciones arriba para ver la previsualización de tu perfil público.</div>`
      return
    }
    sesion.productos.forEach((prod) => {
      const card = document.createElement('div')
      card.className = 'rounded-2xl overflow-hidden flex flex-col'
      card.style.cssText = `border: 2px solid var(--border); background: rgba(${categoriaColor}, 0.18)`
      const titulo = escapeHtml(prod.titulo)
      const desc = escapeHtml(prod.descripcion)
      const precio = prod.precio
      const fotoValida =
        prod.foto &&
        (prod.foto.startsWith('https://') ||
          prod.foto.startsWith('data:image/'))
      const fotoUrl = fotoValida ? escapeHtml(prod.foto!) : ''
      const priceTag =
        precio != null
          ? `<span class="text-emerald-400 font-bold text-xs bg-emerald-950/40 px-2 py-0.5 rounded-lg border border-emerald-500/20 shrink-0">$${precio}</span>`
          : ''
      const imgHtml = fotoUrl
        ? `<div class="w-full h-32 overflow-hidden"><img src="${fotoUrl}" alt="${titulo}" loading="lazy" class="w-full h-full object-cover" /></div>`
        : `<div class="w-full h-16 flex items-center justify-center text-2xl" style="background: var(--button); color: var(--quaternary)">📋</div>`
      card.innerHTML = `${imgHtml}<div class="p-3 space-y-1"><div class="flex items-center gap-2"><h4 class="font-bold text-xs truncate grow" style="color: var(--primary)">${titulo}</h4>${priceTag}</div><p class="text-[10px] line-clamp-2 leading-relaxed" style="color: var(--quaternary)">${desc}</p></div>`
      contenedorCatalogo.appendChild(card)
    })
  }
</script>
