---
import Layout from '../layouts/Layout.astro'
import LogoBrand from '../components/LogoBrand.astro'
import BackButton from '../components/BackButton.astro'
import Footer from '../components/Footer.astro'
---

<Layout title="Comercio Local - Perfil Comercial">
  <main
    id="perfil-contenedor"
    class="max-w-4xl mx-auto px-4 sm:px-6 pt-6 pb-16 flex flex-col min-h-screen justify-between"
  >
    <div
      id="loading-state"
      class="flex flex-col items-center justify-center py-20 grow"
    >
      <div
        class="animate-spin rounded-full h-10 w-10 border-t-2 border-emerald-500 mb-4"
      >
      </div>
      <p class="text-sm" style="color: var(--tertiary)">
        Cargando perfil comercial...
      </p>
    </div>

    <div
      id="error-state"
      class="hidden flex flex-col items-center justify-center py-20 grow text-center"
    >
      <span class="text-4xl mb-4">⚠️</span>
      <h2 class="text-lg font-bold mb-2" style="color: var(--primary)">
        Perfil no encontrado
      </h2>
      <p class="text-sm mb-6 max-w-sm" style="color: var(--tertiary)">
        La cuenta comercial o profesional que estás buscando no existe o fue
        dada de baja.
      </p>
      <a
        href="/"
        class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold px-6 py-3 rounded-2xl text-sm transition-colors active:scale-[0.99]"
      >
        Volver a la cartelera
      </a>
    </div>

    <div id="perfil-real" class="hidden w-full grow space-y-6">
      <div class="flex items-center justify-between pb-2">
        <LogoBrand />
        <BackButton label="Volver a la cartelera" />
      </div>

      <div
        id="perfil-hero"
        class="relative rounded-3xl overflow-hidden backdrop-blur-md"
        style="border: 2px solid var(--border)"
      >
        <div class="h-44 sm:h-60 w-full overflow-hidden relative">
          <img
            id="perfil-portada"
            src=""
            alt="Portada comercial"
            class="w-full h-full object-cover filter brightness-[0.75]"
          />
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, var(--overlay), transparent)"
          >
          </div>
        </div>

        <div
          class="px-6 pb-6 pt-16 relative flex flex-col items-center text-center sm:items-start sm:text-left"
          style="color: var(--secondary)"
        >
          <div
            class="absolute -top-12 left-1/2 -translate-x-1/2 sm:left-6 sm:translate-x-0 w-24 h-24 rounded-full overflow-hidden shadow-xl shrink-0 flex items-center justify-center font-bold text-2xl"
            style="background: var(--surface); border: 4px solid var(--logo-border); color: var(--primary)"
          >
            <img
              id="perfil-logo"
              src=""
              alt="Logo comercial"
              class="w-full h-full object-cover hidden"
            />
            <span id="perfil-iniciales" class="hidden"></span>
          </div>

          <div
            class="w-full flex flex-col sm:flex-row justify-between items-center sm:items-end gap-4 mt-2"
          >
            <div>
              <h2
                id="perfil-nombre"
                class="text-2xl font-bold tracking-wide"
                style="color: var(--primary)"
              >
              </h2>
              <div
                class="flex flex-wrap items-center justify-center sm:justify-start gap-2 mt-1"
              >
                <span
                  id="perfil-categoria"
                  class="text-xs font-semibold px-2.5 py-0.5 rounded-lg"></span>
                <span style="color: var(--quaternary)">•</span>
                <span
                  id="perfil-ubicacion"
                  class="text-xs font-medium"
                  style="color: var(--secondary)"></span>
              </div>
              <a
                id="perfil-sitio-web"
                target="_blank"
                rel="noopener noreferrer"
                class="hidden text-xs mt-1.5 transition-colors"
                style="color: var(--tertiary)"></a>
            </div>

            <a
              id="perfil-whatsapp-link"
              href=""
              target="_blank"
              rel="noopener noreferrer"
              class="bg-emerald-600 hover:bg-emerald-500 text-white font-bold px-6 py-3.5 rounded-2xl text-sm flex items-center gap-2 transition-all active:scale-[0.99] shadow-lg shadow-emerald-950/20 cursor-pointer shrink-0"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397 0 11.948 0c3.179.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.907-11.89 11.907-2.013-.001-3.99-.51-5.772-1.482L0 24zm6.59-4.846c1.63.967 3.56 1.48 5.35 1.481 5.468 0 9.915-4.444 9.918-9.917.002-2.651-1.032-5.143-2.908-7.022C17.07 1.816 14.58 .78 11.948.78c-5.458 0-9.91 4.444-9.914 9.919-.001 1.889.499 3.73 1.447 5.362L2.456 21.23l5.191-1.362z"
                ></path>
              </svg>
              Contactar por WhatsApp
            </a>
          </div>

          <p
            id="perfil-descripcion"
            class="text-sm mt-5 leading-relaxed max-w-2xl text-center sm:text-left"
            style="color: var(--secondary)"
          >
          </p>

          <div
            id="perfil-historia"
            class="hidden mt-4 p-4 rounded-xl text-sm leading-relaxed max-w-2xl text-center sm:text-left"
            style="background: var(--elevated-40); border: 1px solid var(--border); color: var(--secondary)"
          >
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <h3
          class="text-sm font-bold uppercase tracking-widest px-1"
          style="color: var(--tertiary)"
        >
          Catálogo de Productos y Servicios
        </h3>
        <div
          id="perfil-catalogo-grid"
          class="grid grid-cols-1 md:grid-cols-2 gap-6"
        >
        </div>
      </div>
    </div>

    <Footer showLinks={false} />
  </main>
</Layout>

<script>
  import { obtenerPerfilPorId } from '../utils/storage'
  import { COLORES_CATEGORIAS, RESPALDOS_POR_RUBRO } from '../utils/constants'
  import type { PerfilComercio, Producto } from '../utils/constants'
  import {
    calcularIniciales,
    construirLinkWhatsApp,
    detectarRedSocial,
    escapeHtml
  } from '../utils/formatters'

  const loadingState = document.getElementById(
    'loading-state'
  ) as HTMLDivElement
  const errorState = document.getElementById('error-state') as HTMLDivElement
  const perfilReal = document.getElementById('perfil-real') as HTMLDivElement

  const heroContainer = document.getElementById('perfil-hero') as HTMLDivElement

  const imgPortada = document.getElementById(
    'perfil-portada'
  ) as HTMLImageElement
  const imgLogo = document.getElementById('perfil-logo') as HTMLImageElement
  const spanIniciales = document.getElementById(
    'perfil-iniciales'
  ) as HTMLSpanElement

  const txtNombre = document.getElementById(
    'perfil-nombre'
  ) as HTMLHeadingElement
  const spanCategoria = document.getElementById(
    'perfil-categoria'
  ) as HTMLSpanElement
  const spanUbicacion = document.getElementById(
    'perfil-ubicacion'
  ) as HTMLSpanElement
  const txtDescripcion = document.getElementById(
    'perfil-descripcion'
  ) as HTMLParagraphElement
  const linkSitioWeb = document.getElementById(
    'perfil-sitio-web'
  ) as HTMLAnchorElement
  const divHistoria = document.getElementById(
    'perfil-historia'
  ) as HTMLDivElement

  const linkWhatsapp = document.getElementById(
    'perfil-whatsapp-link'
  ) as HTMLAnchorElement
  const gridCatalogo = document.getElementById(
    'perfil-catalogo-grid'
  ) as HTMLDivElement

  const urlParams = new URLSearchParams(window.location.search)
  const id = urlParams.get('id')

  if (!id) {
    showError()
  } else {
    const perfil = await obtenerPerfilPorId(id)
    if (!perfil) {
      showError()
    } else {
      showPerfil(perfil)
    }
  }

  function showError() {
    loadingState.classList.add('hidden')
    errorState.classList.remove('hidden')
  }

  function showPerfil(p: PerfilComercio) {
    loadingState.classList.add('hidden')
    perfilReal.classList.remove('hidden')

    const configColor =
      COLORES_CATEGORIAS[p.categoria] || COLORES_CATEGORIAS.otros
    const respaldos =
      RESPALDOS_POR_RUBRO[p.categoria] || RESPALDOS_POR_RUBRO.otros

    heroContainer.style.cssText = `background: rgba(${configColor.rgb}, 0.22); border: 2px solid var(--border)`

    imgPortada.src = p.fotoPortada || respaldos.portada

    if (p.fotoLogo) {
      imgLogo.src = p.fotoLogo
      imgLogo.classList.remove('hidden')
      spanIniciales.classList.add('hidden')
    } else {
      const iniciales = calcularIniciales(p.nombreEmprendimiento)
      spanIniciales.textContent = iniciales
      spanIniciales.className = `w-full h-full flex items-center justify-center`
      spanIniciales.style.background = 'var(--surface)'
      spanIniciales.style.color = 'var(--primary)'
      spanIniciales.classList.remove('hidden')
      imgLogo.classList.add('hidden')
    }

    txtNombre.textContent = p.nombreEmprendimiento
    txtDescripcion.textContent = p.descripcion

    spanCategoria.textContent = p.categoria
    spanCategoria.className = `text-xs font-semibold px-2.5 py-0.5 rounded-lg uppercase tracking-wider ${configColor.fullClass}`

    spanUbicacion.textContent = p.direccion
      ? `📍 ${p.ciudad} • ${p.direccion}`
      : `📍 ${p.ciudad}`

    if (p.sitioWeb) {
      const red = detectarRedSocial(p.sitioWeb)
      const iconos: Record<string, string> = {
        instagram: '📷',
        facebook: '👍',
        web: '🌐'
      }
      linkSitioWeb.href = p.sitioWeb
      linkSitioWeb.textContent = `${iconos[red]} ${p.sitioWeb}`
      linkSitioWeb.classList.remove('hidden')
    } else {
      linkSitioWeb.classList.add('hidden')
    }

    if (p.historia) {
      divHistoria.textContent = p.historia
      divHistoria.classList.remove('hidden')
    } else {
      divHistoria.classList.add('hidden')
    }

    linkWhatsapp.href = construirLinkWhatsApp(
      p.whatsapp,
      p.nombreEmprendimiento
    )

    gridCatalogo.innerHTML = ''

    if (p.productos.length === 0) {
      gridCatalogo.className = 'w-full'
      gridCatalogo.innerHTML = `
        <div class="col-span-1 md:col-span-2 text-center py-12 p-6 italic text-sm rounded-3xl" style="background: rgba(${configColor.rgb}, 0.18); border: 2px solid var(--border); color: var(--tertiary)">
          Este profesional o comerciante aún no cargó trabajos en su perfil.
        </div>
      `
      return
    }

    gridCatalogo.className = 'grid grid-cols-1 md:grid-cols-2 gap-6'

    p.productos.forEach((prod: Producto) => {
      const card = document.createElement('div')
      card.className =
        'rounded-3xl overflow-hidden flex flex-col justify-between border-2'
      card.style.cssText = `background: rgba(${configColor.rgb}, 0.18); border-color: var(--border)`

      const titulo = escapeHtml(prod.titulo)
      const descripcion = escapeHtml(prod.descripcion)
      const precio = prod.precio
      const fotoValida =
        prod.foto &&
        (prod.foto.startsWith('https://') ||
          prod.foto.startsWith('data:image/'))
      const fotoUrl = fotoValida ? escapeHtml(prod.foto!) : ''

      const priceTag =
        precio !== undefined
          ? `<span class="font-bold text-sm px-2.5 py-1 rounded-xl shrink-0" style="color: var(--primary); background: var(--elevated)">$${precio}</span>`
          : ''

      const imgSeccion = fotoUrl
        ? `<div class="w-full h-48 overflow-hidden relative" style="border-bottom: 1px solid var(--border-strongest)"><img src="${fotoUrl}" alt="${titulo}" loading="lazy" class="w-full h-full object-cover" /></div>`
        : `<div class="w-full h-24 flex items-center justify-center px-6" style="background: var(--elevated); border-bottom: 1px solid var(--border-strongest)"><p class="text-sm italic text-center line-clamp-3 leading-relaxed" style="color: var(--tertiary)">${descripcion}</p></div>`

      card.innerHTML = `
        <div>
          ${imgSeccion}
          <div class="p-5 space-y-2">
            <div class="flex justify-between items-start gap-4">
              <h4 class="font-bold text-base leading-tight" style="color: var(--primary)">${titulo}</h4>
              ${priceTag}
            </div>
            <p class="text-xs leading-relaxed" style="color: var(--tertiary)">${descripcion}</p>
          </div>
        </div>

        <div class="px-5 pb-5">
          <a
            href="${construirLinkWhatsApp(p.whatsapp, p.nombreEmprendimiento, prod.titulo)}"
            target="_blank"
            rel="noopener noreferrer"
            class="w-full py-3 rounded-2xl text-xs font-bold flex items-center justify-center gap-1.5 transition-colors active:scale-[0.99] cursor-pointer"
            style="background: var(--button); border: 1px solid var(--border-strong); color: var(--secondary)"
          >
            Consultar por este trabajo
          </a>
        </div>
      `

      gridCatalogo.appendChild(card)
    })
  }
</script>
