---
import Layout from '../layouts/Layout.astro'
import BackButton from '../components/BackButton.astro'
import Footer from '../components/Footer.astro'
import Alert from '../components/Alert.astro'
import SocialButtons from '../components/SocialButtons.astro'
---

<Layout title="Comercio Local - Iniciar Sesión">
  <main
    class="max-w-md mx-auto px-6 pt-12 pb-12 flex flex-col min-h-screen justify-between"
  >
    <div class="w-full">
      <div
        class="flex items-center justify-between pb-4 mb-8"
        style="border-bottom: 1px solid var(--border-strongest)"
      >
        <h1
          class="text-2xl font-bold tracking-wide"
          style="color: var(--primary)"
        >
          Comercio Local
        </h1>
        <BackButton />
      </div>

      <div
        class="p-6 rounded-3xl border backdrop-blur-md"
        style="background: var(--elevated-60); border-color: var(--border-strongest)"
      >
        <SocialButtons mode="login" />

        <Alert type="error" id="alerta-error" />

        <form id="form-login" class="space-y-5">
          <div>
            <label
              for="email"
              class="block text-xs font-semibold uppercase tracking-wider mb-2"
              style="color: var(--tertiary)"
            >
              Correo Electrónico
            </label>
            <input
              id="email"
              type="email"
              required
              placeholder="tu@correo.com"
              class="w-full px-4 py-3.5 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
              style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
            />
          </div>

          <div>
            <label
              for="password"
              class="block text-xs font-semibold uppercase tracking-wider mb-2"
              style="color: var(--tertiary)"
            >
              Contraseña
            </label>
            <input
              id="password"
              type="password"
              required
              placeholder="••••••••"
              class="w-full px-4 py-3.5 rounded-2xl text-sm focus:outline-none focus:border-emerald-500 transition-colors"
              style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
            />
          </div>

          <button
            type="submit"
            class="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-3.5 rounded-2xl text-sm font-bold flex items-center justify-center gap-2 transition-colors active:scale-[0.99] mt-6 cursor-pointer"
          >
            Iniciar Sesión
          </button>
        </form>
      </div>

      <div class="mt-6 text-center text-sm" style="color: var(--tertiary)">
        ¿Aún no tenés cuenta de creador?
        <a
          href="/registro"
          class="text-emerald-400 font-semibold underline hover:text-emerald-300 ml-1 transition-colors"
        >
          Registrate acá
        </a>
      </div>

      <div
        class="mt-8 p-4 rounded-2xl text-xs space-y-2"
        style="background: var(--modal-overlay); border: 1px solid var(--border-strong); color: var(--quaternary)"
      >
        <p class="font-bold" style="color: var(--secondary)">
          💡 Cuentas de Demostración:
        </p>
        <p>
          • <strong>Mabel:</strong> mabel@local.com / mabel123 (Comida, Ayacucho)
        </p>
        <p>
          • <strong>Carlos:</strong> carlos@local.com / carlos123 (Oficios, Tandil)
        </p>
      </div>
    </div>

    <Footer showLinks={false} />
  </main>
</Layout>

<script>
  import { autenticarUsuario, obtenerSesionActiva } from '../utils/storage'
  import { mostrarError } from '../utils/ui'

  const sesion = await obtenerSesionActiva()
  if (sesion) {
    window.location.href = '/dashboard'
  }

  const form = document.getElementById('form-login') as HTMLFormElement
  const emailInput = document.getElementById('email') as HTMLInputElement
  const passwordInput = document.getElementById('password') as HTMLInputElement
  const alertaError = document.getElementById('alerta-error') as HTMLDivElement
  const alertaErrorTexto = document.getElementById(
    'alerta-error-texto'
  ) as HTMLSpanElement

  form?.addEventListener('submit', async (e) => {
    e.preventDefault()

    const email = emailInput.value
    const password = passwordInput.value

    alertaError.classList.add('hidden')

    const res = await autenticarUsuario(email, password)

    if (res.success) {
      window.location.href = '/dashboard'
    } else {
      mostrarError(alertaError, alertaErrorTexto, res.message)
    }
  })
</script>
