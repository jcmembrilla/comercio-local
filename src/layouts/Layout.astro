---
import '../styles/global.css'
import Toast from '../components/Toast.astro'
import ThemeToggle from '../components/ThemeToggle.astro'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Comercio Local - Impulsando el comercio artesanal y local'
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta
      property="og:image"
      content="https://comercio-local.netlify.app/favicon.svg"
    />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" is:inline>
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "Comercio Local",
        "url": "https://comercio-local.netlify.app",
        "description": "Cartelera digital para visibilizar emprendedores, productores y trabajadores independientes de tu localidad.",
        "inLanguage": "es"
      }
    </script>
    <title>{title}</title>
    <script>
      ;(function () {
        const t = localStorage.getItem('comercio_local_theme')
        if (t !== 'dark') document.documentElement.classList.add('light')
      })()
    </script>
  </head>
  <body
    class="min-h-screen font-sans antialiased"
    style="background: var(--body-bg); color: var(--primary)"
  >
    <div class="fixed top-4 right-4 z-50">
      <ThemeToggle />
    </div>
    <slot />
    <Toast />
  </body>
</html>

<script>
  import { initTheme } from '../utils/theme'
  initTheme()

  import { supabase } from '../utils/supabase'
  supabase.auth.onAuthStateChange((event) => {
    if (event === 'TOKEN_REFRESHED' || event === 'SIGNED_OUT') {
      window.location.reload()
    }
  })
</script>
