---
interface Props {
  showLinks?: boolean
}

const { showLinks = true } = Astro.props
---

<footer
  class="w-full pt-12 pb-2 text-center space-y-1.5 text-xs tracking-wide"
  style="color: var(--tertiary)"
>
  <p>&copy; 2026 Comercio Local</p>
  {
    showLinks && (
      <div class="flex justify-center gap-4">
        <a
          href="/nosotros"
          class="underline transition-colors"
          style="color: var(--tertiary)"
        >
          ¿Quiénes somos?
        </a>
        <span style="color: var(--quaternary)">•</span>
        <a
          href="/nosotros#normas"
          class="underline transition-colors"
          style="color: var(--tertiary)"
        >
          Normas de convivencia
        </a>
        <span style="color: var(--quaternary)">•</span>
        <a
          href="/nosotros#legales"
          class="underline transition-colors"
          style="color: var(--tertiary)"
        >
          Términos legales
        </a>
      </div>
    )
  }
</footer>
