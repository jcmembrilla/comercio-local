---
interface Props {
  showLocalidad?: boolean
}

const { showLocalidad = true } = Astro.props
---

<header
  class="flex flex-col sm:flex-row items-center justify-between gap-4 border-b border-[#2A2A2A] pb-6 mb-8 w-full"
>
  <a href="/" class="flex items-center gap-2 group shrink-0">
    <span class="text-2xl">🌱</span>
    <div>
      <h1
        class="text-2xl font-bold tracking-wide text-white group-hover:text-emerald-400 transition-colors"
      >
        Comercio Local
      </h1>
      {
        showLocalidad && (
          <p
            id="localidad-detectada-texto"
            class="text-[11px] text-emerald-400 font-semibold mt-0.5 transition-all"
          >
            Localidad: Cargando...
          </p>
        )
      }
    </div>
  </a>

  <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
    {
      showLocalidad && (
        <div class="relative min-w-[150px]">
          <select
            id="selector-ciudad-cabecera"
            class="w-full bg-[#1E1E1E] text-emerald-400 pl-3 pr-8 py-2.5 rounded-xl border border-[#333] text-xs font-bold appearance-none focus:outline-none focus:border-emerald-500 cursor-pointer transition-colors"
          >
            <option value="todas">📍 Todas las localidades</option>
          </select>
          <div class="absolute inset-y-0 right-2 flex items-center pointer-events-none text-emerald-400">
            <svg
              class="w-3 h-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </div>
        </div>
      )
    }

    <a
      id="btn-auth-cabecera"
      href="/login"
      class="text-xs bg-[#1E1E1E] hover:bg-emerald-600 hover:text-white text-gray-300 font-bold px-4 py-2.5 rounded-xl border border-[#333] transition-all flex items-center gap-1.5 shrink-0"
    >
      🚪 Ingresar
    </a>
  </div>
</header>
