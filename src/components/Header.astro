---
interface Props {
  showLocalidad?: boolean
}

const { showLocalidad = true } = Astro.props
---

<header
  class="flex flex-col sm:flex-row items-center justify-between gap-4 border-b pb-6 mb-8 w-full"
  style="border-color: var(--border-strongest)"
>
  <a href="/" class="flex items-center gap-2 group shrink-0">
    <span class="text-2xl">🌱</span>
    <div>
      <h1
        class="text-2xl font-bold tracking-wide"
        style="color: var(--primary)"
        class:list={{ 'group-hover:text-emerald-400 transition-colors': true }}
      >
        Comercio Local
      </h1>
    </div>
  </a>

  <div class="flex items-center gap-3 w-full sm:w-auto justify-end">
    {
      showLocalidad && (
        <div class="relative min-w-[150px]">
          <select
            id="selector-ciudad-cabecera"
            class="w-full py-2.5 rounded-xl text-xs font-bold appearance-none focus:outline-none focus:border-emerald-500 cursor-pointer transition-colors pl-3 pr-8"
            style="background: var(--elevated); color: var(--primary); border-color: var(--border-strong)"
          >
            <option value="" disabled selected>
              Cargando...
            </option>
          </select>
          <div
            class="absolute inset-y-0 right-2 flex items-center pointer-events-none"
            style="color: var(--primary)"
          >
            <svg
              class="w-3 h-3"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </div>
        </div>
      )
    }

    <a
      id="btn-auth-cabecera"
      href="/login"
      class="text-xs font-bold px-4 py-2.5 rounded-xl transition-all flex items-center gap-1.5 shrink-0"
      style="background: var(--elevated); color: var(--secondary); border: 1px solid var(--border-strong)"
    >
      🚪 Ingresar
    </a>
  </div>
</header>
