---
interface Props {
  href?: string
  label?: string
}

const { href = '/', label = 'Volver' } = Astro.props
---

<a
  href={href}
  class="text-xs px-3 py-2 rounded-xl border transition-all"
  style="background: var(--elevated); color: var(--secondary); border-color: var(--border-strong);"
  class:list={{
    'hover:bg-emerald-950/30 hover:text-emerald-400 hover:border-emerald-800/40': true
  }}
>
  &larr; {label}
</a>
