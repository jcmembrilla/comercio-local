---
interface Props {
  id: string
  label: string
  accept?: string
  maxSize?: string
}

const {
  id,
  label,
  accept = 'image/*',
  maxSize = 'JPG, PNG, WebP · Máx 2MB'
} = Astro.props

const inputId = `foto_${id}`
const previewId = `preview-${id}`
const placeholderId = `placeholder-${id}`
---

<div>
  <label
    class="block text-xs font-semibold uppercase tracking-wider mb-2"
    style="color: var(--tertiary)"
  >
    {label}
  </label>
  <label
    for={inputId}
    class="group flex flex-col items-center justify-center gap-2 w-full h-28 rounded-2xl border-2 border-dashed hover:border-emerald-500/50 cursor-pointer transition-all relative overflow-hidden"
    style="background: var(--elevated); border-color: var(--border-strong)"
  >
    <img
      id={previewId}
      src=""
      alt=""
      class="hidden w-full h-full object-cover absolute inset-0 rounded-2xl"
    />
    <div
      id={placeholderId}
      class="flex flex-col items-center gap-1.5 pointer-events-none"
    >
      <svg
        class="w-7 h-7 transition-colors"
        style="color: var(--quaternary)"
        class:list={{ 'group-hover:text-emerald-500 transition-colors': true }}
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"
        ></path>
      </svg>
      <span
        class="text-[10px] transition-colors font-medium"
        style="color: var(--quaternary)"
        class:list={{ 'group-hover:text-emerald-400 transition-colors': true }}
        >Subir {label.toLowerCase()}</span
      >
      <span class="text-[9px]" style="color: var(--quaternary)">{maxSize}</span>
    </div>
  </label>
  <input id={inputId} type="file" accept={accept} class="hidden" />
</div>
