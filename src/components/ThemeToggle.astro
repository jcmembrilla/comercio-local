<button
  id="btn-tema"
  class="text-sm w-9 h-9 rounded-xl flex items-center justify-center transition-colors shrink-0 cursor-pointer"
  style="background: var(--elevated); color: var(--primary); border: 1px solid var(--border-strong)"
  aria-label="Cambiar tema"
  title="Cambiar tema"
>
  <svg
    id="icono-sol"
    class="w-4 h-4 hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M12 3v1m0 16v1m8.66-13.66l-.71.71M4.05 19.95l-.71.71M21 12h-1M4 12H3m16.66 7.66l-.71-.71M4.05 4.05l-.71-.71M16 12a4 4 0 11-8 0 4 4 0 018 0z"
    ></path>
  </svg>
  <svg
    id="icono-luna"
    class="w-4 h-4 hidden"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
  </svg>
</button>

<script is:inline>
  ;(function () {
    const btn = document.getElementById('btn-tema')
    const iconoSol = document.getElementById('icono-sol')
    const iconoLuna = document.getElementById('icono-luna')

    function obtenerTema() {
      try {
        const stored = localStorage.getItem('comercio_local_theme')
        if (stored === 'light' || stored === 'dark') return stored
      } catch {
        // noop
      }
      return 'light'
    }

    function aplicarTema(tema) {
      try {
        document.documentElement.classList.toggle('light', tema === 'light')
      } catch {
        // noop
      }
    }

    function cambiarTema(tema) {
      try {
        localStorage.setItem('comercio_local_theme', tema)
      } catch {
        // noop
      }
      aplicarTema(tema)
    }

    function syncIcons(tema) {
      if (!iconoSol || !iconoLuna) return
      iconoSol.classList.toggle('hidden', tema === 'light')
      iconoLuna.classList.toggle('hidden', tema === 'dark')
    }

    const inicial = obtenerTema()
    aplicarTema(inicial)
    syncIcons(inicial)

    btn?.addEventListener('click', () => {
      const actual = obtenerTema()
      const nuevo = actual === 'dark' ? 'light' : 'dark'
      cambiarTema(nuevo)
      syncIcons(nuevo)
    })
  })()
</script>
